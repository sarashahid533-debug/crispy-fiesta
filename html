<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Galaxy Scanner</title>
  <style>
    /* Reset & Base Styles */
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background-color: #f0f4ff;
      color: #333;
      line-height: 1.5;
    }

    /* Navbar Styles */
    .navbar {
      background-color: #1a237e;
      padding: 0.75rem 1.5rem;
      display: flex;
      align-items: center;
    }
    .navbar-brand {
      color: white !important;
      font-size: 1.25rem;
      font-weight: bold;
      text-decoration: none;
      margin-right: 1.5rem;
    }
    .navbar-nav {
      display: flex;
      list-style: none;
      gap: 1rem;
    }
    .nav-link {
      color: white !important;
      text-decoration: none;
      font-size: 0.95rem;
      opacity: 0.85;
    }
    .nav-link:hover {
      opacity: 1;
    }

    /* Main Grid & Layout Container */
    .container {
      max-width: 1140px;
      margin: 2rem auto;
      padding: 0 1rem;
    }
    .section-margin {
      margin-bottom: 2.5rem;
    }
    h4 {
      font-size: 1.5rem;
      margin-bottom: 1rem;
      color: #1a237e;
    }

    /* Spinner Animation Styles */
    .spinner-border {
      display: inline-block;
      width: 2rem;
      height: 2rem;
      vertical-align: middle;
      border: 0.25em solid currentColor;
      border-right-color: transparent;
      border-radius: 50%;
      animation: spinner .75s linear infinite;
      margin-right: 0.5rem;
    }
    .text-primary { color: #0d6efd; }
    .text-warning { color: #ffc107; }
    .text-danger { color: #dc3545; }
    @keyframes spinner {
      to { transform: rotate(360deg); }
    }

    /* Card System Styles */
    .row {
      display: flex;
      flex-wrap: wrap;
      margin-right: -0.75rem;
      margin-left: -0.75rem;
    }
    .col-md-4 {
      flex: 0 0 auto;
      width: 33.333333%;
      padding-right: 0.75rem;
      padding-left: 0.75rem;
    }
    .card {
      background-color: white;
      border: 1px solid rgba(0,0,0,.125);
      border-radius: 0.375rem;
      height: 100%;
      display: flex;
      flex-direction: column;
    }
    .card-body {
      padding: 1.25rem;
      flex: 1 1 auto;
      display: flex;
      flex-direction: column;
    }
    .card-title {
      font-size: 1.25rem;
      margin-bottom: 0.5rem;
      font-weight: 500;
    }
    .card-text {
      margin-bottom: 1rem;
      color: #555;
      flex-grow: 1;
    }
    .btn {
      display: inline-block;
      font-weight: 400;
      text-align: center;
      white-space: nowrap;
      vertical-align: middle;
      user-select: none;
      border: 1px solid transparent;
      padding: 0.375rem 0.75rem;
      font-size: 1rem;
      line-height: 1.5;
      border-radius: 0.25rem;
      text-decoration: none;
    }
    .btn-primary {
      color: #fff;
      background-color: #0d6efd;
      border-color: #0d6efd;
      align-self: flex-start;
    }

    /* Pagination Component Styles */
    .pagination {
      display: flex;
      padding-left: 0;
      list-style: none;
      border-radius: 0.25rem;
    }
    .page-link {
      padding: 0.375rem 0.75rem;
      color: #0d6efd;
      text-decoration: none;
      background-color: #fff;
      border: 1px solid #dee2e6;
    }
    .page-item:first-child .page-link {
      border-top-left-radius: 0.25rem;
      border-bottom-left-radius: 0.25rem;
    }
    .page-item:last-child .page-link {
      border-top-right-radius: 0.25rem;
      border-bottom-right-radius: 0.25rem;
    }
    .page-link:hover {
      background-color: #e9ecef;
      border-color: #dee2e6;
    }

    /* Mobile Responsive Rule */
    @media (max-width: 768px) {
      .col-md-4 {
        width: 100%;
        margin-bottom: 1rem;
      }
    }
  </style>
</head>
<body>

  <!-- Navigation Bar -->
  <nav class="navbar">
    <a class="navbar-brand" href="#">Galaxy Scanner</a>
    <ul class="navbar-nav">
      <li class="nav-item"><a class="nav-link" href="#">Home</a></li>
      <li class="nav-item"><a class="nav-link" href="#">Planets</a></li>
      <li class="nav-item"><a class="nav-link" href="#">Stars</a></li>
    </ul>
  </nav>

  <!-- Main Content Container -->
  <div class="container">
    
    <!-- Spinners Section -->
    <div class="section-margin">
      <h4>Scanning the Galaxy...</h4>
      <div class="spinner-border text-primary"></div>
      <div class="spinner-border text-warning"></div>
      <div class="spinner-border text-danger"></div>
    </div>

    <!-- Planet Cards Section -->
    <div class="section-margin">
      <h4>Featured Planets</h4>
      <div class="row">
        
        <!-- Card 1 -->
        <div class="col-md-4">
          <div class="card">
            <div class="card-body">
              <h5 class="card-title">Mars</h5>
              <p class="card-text">Explore the red planet's desert landscapes and deep canyons.</p>
              <a href="#" class="btn btn-primary">Explore</a>
            </div>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="col-md-4">
          <div class="card">
            <div class="card-body">
              <h5 class="card-title">Jupiter</h5>
              <p class="card-text">Discover the largest gas giant and its iconic stormy eye.</p>
              <a href="#" class="btn btn-primary">Explore</a>
            </div>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="col-md-4">
          <div class="card">
            <div class="card-body">
              <h5 class="card-title">Saturn</h5>
              <p class="card-text">Admire the spectacular ring system orbiting this massive planet.</p>
              <a href="#" class="btn btn-primary">Explore</a>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Pagination Section -->
    <div class="section-margin">
      <h4>Browse More Planets</h4>
      <ul class="pagination">
        <li class="page-item"><a class="page-link" href="#">Previous</a></li>
        <li class="page-item"><a class="page-link" href="#">1</a></li>
        <li class="page-item"><a class="page-link" href="#">2</a></li>
        <li class="page-item"><a class="page-link" href="#">3</a></li>
        <li class="page-item"><a class="page-link" href="#">Next</a></li>
      </ul>
    </div>

  </div>

</body>
</html>
